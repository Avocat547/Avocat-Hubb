-- Notification style Xeno (juste un petit texte qui slide)
local function ShowNotif(text)
    local old = CoreGui:FindFirstChild("AimbotNotif")
    if old then old:Destroy() end

    local g = Instance.new("ScreenGui")
    g.Name = "AimbotNotif"
    g.ResetOnSpawn = false
    g.Parent = CoreGui

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0, 200, 0, 30)
    lbl.Position = UDim2.new(1, -210, 1, 50)
    lbl.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    lbl.BackgroundTransparency = 0.2
    lbl.BorderSizePixel = 0
    lbl.Text = text
    lbl.TextColor3 = Color3.new(1, 1, 1)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.Parent = g

    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 6)
    c.Parent = lbl

    -- Slide in
    TweenService:Create(lbl,
        TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Position = UDim2.new(1, -210, 1, -40)}
    ):Play()

    task.delay(2, function()
        if not lbl or not lbl.Parent then return end
        local tout = TweenService:Create(lbl,
            TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
            {Position = UDim2.new(1, -210, 1, 50)}
        )
        tout:Play()
        tout.Completed:Connect(function()
            if g and g.Parent then g:Destroy() end
        end)
    end)
end

