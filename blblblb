RunService.RenderStepped:Connect(function()
    UpdateESP()
    if not Active then return end

    if not Target then
        Target = GetClosest()
        if not Target then return end
    end

    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local head = Target:FindFirstChild("Head") or Target:FindFirstChild("HumanoidRootPart")
    local root = Target:FindFirstChild("HumanoidRootPart")
    local hum  = Target:FindFirstChildWhichIsA("Humanoid")

    if not head or not root or not hum or hum.Health <= 0 then
        Target = GetClosest()
        return
    end

    if not IsVisible(root) then
        Target = GetClosest()
        return
    end

    local _, onScreen = Camera:WorldToViewportPoint(head.Position)
    if not onScreen then
        Target = GetClosest()
        return
    end

    local dist3D = (myRoot.Position - root.Position).Magnitude
    local predFactor = math.clamp(dist3D / 100, 0.02, 0.12)
    local vel = head.AssemblyLinearVelocity or Vector3.zero
    local worldPos = head.Position
    if vel.Magnitude > 0 then
        worldPos = worldPos + vel * predFactor
    end

    local scr    = Camera:WorldToScreenPoint(worldPos)
    local diffX  = scr.X - Mouse.X
    local diffY  = scr.Y - Mouse.Y
    local dist2D = math.sqrt(diffX * diffX + diffY * diffY)

    if dist2D > 0.5 and mousemoverel then
        mousemoverel(diffX, diffY)
    end

    local fireThresh = dist3D < 10 and 30 or 10
    if dist2D < fireThresh and not Firing then
        Click()
    end
end)
