-- ESP
local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "ESPFolder"
ESPFolder.Parent = CoreGui
local ESPHighlights = {}

local function IsVisible(part)
    if not part then return false end
    local origin = Camera.CFrame.Position
    local dir    = part.Position - origin
    local ray    = Ray.new(origin, dir.Unit * dir.Magnitude)
    local hit    = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
    return hit and (hit:IsDescendantOf(part.Parent) or hit == part)
end

function GetClosest()
    local best, bestDist = nil, math.huge
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character then continue end
        if Settings.TeamCheck and plr.Team == LocalPlayer.Team then continue end

        local char = plr.Character
        local part = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildWhichIsA("Humanoid")
        if not part or not hum or hum.Health <= 0 then continue end

        local dist = (myRoot.Position - part.Position).Magnitude
        if dist > 2000 then continue end
        if not IsVisible(part) then continue end

        local _, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end

        if dist < bestDist then
            best     = char
            bestDist = dist
        end
    end
    return best
end

local function SetupHighlight(plr)
    if not plr or not plr.Character then return end
    if ESPHighlights[plr] and ESPHighlights[plr].Parent then return end
    if ESPHighlights[plr] then ESPHighlights[plr]:Destroy() ESPHighlights[plr] = nil end

    local hl = Instance.new("Highlight")
    hl.Adornee             = plr.Character
    hl.FillColor           = Color3.new(1, 1, 1)
    hl.OutlineColor        = Color3.new(1, 1, 1)
    hl.FillTransparency    = 0.5
    hl.OutlineTransparency = 0
    hl.Parent = ESPFolder
    ESPHighlights[plr] = hl
end

local function RemoveHighlight(plr)
    if ESPHighlights[plr] then ESPHighlights[plr]:Destroy() ESPHighlights[plr] = nil end
end

local function UpdateESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if Settings.TeamCheck and plr.Team == LocalPlayer.Team then RemoveHighlight(plr) continue end
        if not plr.Character then RemoveHighlight(plr) continue end
        local hum = plr.Character:FindFirstChildWhichIsA("Humanoid")
        if not hum or hum.Health <= 0 then RemoveHighlight(plr) continue end
        SetupHighlight(plr)
        if ESPHighlights[plr] then ESPHighlights[plr].Adornee = plr.Character end
    end
    for plr, hl in pairs(ESPHighlights) do
        if not plr or not plr.Parent then hl:Destroy() ESPHighlights[plr] = nil end
    end
end

local function Click()
    if Firing then return end
    Firing = true
    task.spawn(function()
        mouse1press()
        task.wait(0.005)
        mouse1release()
        task.wait(0.005)
        Firing = false
    end)
end

for _, plr in ipairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then SetupHighlight(plr) end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(0.1)
        RemoveHighlight(plr)
        SetupHighlight(plr)
