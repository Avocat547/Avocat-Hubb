        {Size = UDim2.new(progress, 0, 1, 0)}):Play()
    local startVal = tonumber((percent.Text:gsub("%%", ""))) or 0
    local endVal = math.floor(progress * 100)
    for j = 1, 20 do
        percent.Text = math.floor(startVal + (endVal - startVal) * (j / 20)) .. "%"
        task.wait(0.02)
    end
    task.wait(0.1)
end

